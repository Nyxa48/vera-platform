@page
@model Vera.Pages.RegisterModel
@{
    ViewData["Title"] = "Yeni Bir Başlangıç";
}

<div class="min-h-[85vh] flex items-center justify-center p-6">
    <div class="max-w-5xl w-full bg-white dark:bg-[#1E2330] rounded-[3rem] shadow-2xl overflow-hidden flex flex-col md:flex-row border border-gray-100 dark:border-gray-800">
        
        <div class="md:w-1/2 p-12 space-y-6">
            <div class="space-y-2">
                <span class="px-3 py-1 bg-pink-100 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400 text-[10px] font-bold uppercase tracking-widest rounded-full">Yeni Hesap</span>
                <h2 class="text-3xl font-black tracking-tighter mt-2">Serüvene Başla</h2>
                <p class="text-gray-400 text-sm font-medium">Vera ile freelance dünyasında yeni bir standart belirle.</p>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <button class="w-full py-3.5 border border-gray-200 dark:border-gray-700 dark:bg-[#151923] rounded-2xl flex items-center justify-center gap-2 hover:bg-gray-50 dark:hover:bg-gray-800 transition font-bold text-xs">
                    <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="w-4 h-4" />
                    Google
                </button>
                <button class="w-full py-3.5 bg-[#1877F2] text-white rounded-2xl flex items-center justify-center gap-2 hover:bg-[#166fe5] transition font-bold text-xs">
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
                    Facebook
                </button>
            </div>

            <div class="relative flex py-1 items-center">
                <div class="flex-grow border-t border-gray-100 dark:border-gray-700"></div>
                <span class="flex-shrink mx-4 text-gray-400 text-[10px] uppercase tracking-widest font-black">VEYA FORM İLE</span>
                <div class="flex-grow border-t border-gray-100 dark:border-gray-700"></div>
            </div>

            <form method="post" class="space-y-3">
                <input asp-for="FullName" type="text" placeholder="Ad Soyad" required class="w-full px-5 py-3.5 rounded-2xl bg-gray-50 dark:bg-[#151923] border-none focus:ring-2 ring-pink-500 transition-all text-sm outline-none">
                <input asp-for="Email" type="email" placeholder="E-posta adresi" required class="w-full px-5 py-3.5 rounded-2xl bg-gray-50 dark:bg-[#151923] border-none focus:ring-2 ring-pink-500 transition-all text-sm outline-none">
                <input asp-for="Password" type="password" placeholder="Güçlü bir şifre oluştur" required class="w-full px-5 py-3.5 rounded-2xl bg-gray-50 dark:bg-[#151923] border-none focus:ring-2 ring-pink-500 transition-all text-sm outline-none">

                <div class="pt-2">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest pl-2 mb-2 block">Nasıl Başlamak İstersin?</label>
                    <div class="grid grid-cols-2 gap-3">
                        <label class="cursor-pointer group">
                            <input type="radio" asp-for="Role" value="Freelancer" class="peer hidden" checked>
                            <div class="px-4 py-3 bg-gray-50 dark:bg-[#151923] border-2 border-transparent rounded-2xl text-center transition-all peer-checked:border-pink-500 peer-checked:bg-pink-50 dark:peer-checked:bg-pink-500/10 hover:bg-gray-100 dark:hover:bg-gray-800">
                                <span class="text-xl mb-1 block">👨‍💻</span>
                                <span class="text-xs font-bold text-gray-700 dark:text-gray-300 peer-checked:text-pink-600 dark:peer-checked:text-pink-400">Freelancer</span>
                            </div>
                        </label>
                        <label class="cursor-pointer group">
                            <input type="radio" asp-for="Role" value="Employer" class="peer hidden">
                            <div class="px-4 py-3 bg-gray-50 dark:bg-[#151923] border-2 border-transparent rounded-2xl text-center transition-all peer-checked:border-pink-500 peer-checked:bg-pink-50 dark:peer-checked:bg-pink-500/10 hover:bg-gray-100 dark:hover:bg-gray-800">
                                <span class="text-xl mb-1 block">🏢</span>
                                <span class="text-xs font-bold text-gray-700 dark:text-gray-300 peer-checked:text-pink-600 dark:peer-checked:text-pink-400">İşveren</span>
                            </div>
                        </label>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="p-3 bg-red-50 dark:bg-red-500/10 text-red-600 text-xs font-bold rounded-xl text-center mt-2 border border-red-100 dark:border-red-500/20">
                        @Model.ErrorMessage
                    </div>
                }

                <button type="submit" class="w-full bg-pink-600 text-white font-bold py-4 mt-2 rounded-2xl shadow-lg shadow-pink-500/30 hover:bg-pink-700 transition active:scale-95 text-sm">Ücretsiz Hesabımı Oluştur</button>
            </form>

            <p class="text-center text-xs text-gray-500">Zaten bir hesabın var mı? <a asp-page="/Login" class="text-pink-600 font-bold hover:underline">Giriş Yap</a></p>
        </div>

        <div class="md:w-1/2 bg-gradient-to-tr from-pink-600 via-purple-600 to-blue-600 p-12 flex flex-col justify-between text-white relative">
            <div class="absolute top-10 right-10 w-32 h-32 bg-white/10 rounded-full blur-3xl animate-pulse"></div>

            <div class="relative z-10 space-y-6">
                <h3 class="text-5xl font-black leading-tight tracking-tighter italic">potansiyelini <br /> serbest bırak.</h3>
                <p class="text-pink-50 text-base font-medium opacity-90 leading-relaxed">
                    Vera sadece bir takip aracı değil; senin dijital asistanın, muhasebecin ve en yakın iş ortağın.
                </p>
            </div>
            
            <div class="relative z-10 pt-8 border-t border-white/20">
                <div class="flex items-center gap-5">
                    <div class="flex -space-x-3 hover:space-x-1 transition-all duration-300">
                        <img class="w-11 h-11 rounded-full border-2 border-pink-400 object-cover shadow-lg" src="https://i.pravatar.cc/100?img=47" alt="User 4">
                        <img class="w-11 h-11 rounded-full border-2 border-pink-400 object-cover shadow-lg" src="https://i.pravatar.cc/100?img=44" alt="User 5">
                        <div class="w-11 h-11 rounded-full border-2 border-pink-400 bg-white flex items-center justify-center text-[11px] font-black text-pink-600 shadow-lg">
                            +12k
                        </div>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[11px] font-black text-white uppercase tracking-widest drop-shadow-md">TOPLULUĞA KATIL</p>
                        <p class="text-[11px] text-pink-100 font-medium opacity-90">Senin gibi binlerce yetenek burada.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>  