@page
@model Vera.Pages.AboutModel
@{
    ViewData["Title"] = "Hakkımızda | Vera Platform";
}

<!-- Ana kapsayıcı, arka planı Layout'tan alır. Ekstra arka plan rengi yok. -->
<div class="relative py-12 md:py-20 space-y-32">
    
    <!-- Dekoratif Arka Plan Gradient'leri (Layout zeminine karışır) -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-[500px] opacity-30 dark:opacity-20 pointer-events-none -z-10">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-500/50 to-purple-600/50 rounded-full blur-[120px]"></div>
    </div>

    <!-- HERO SECTION -->
    <div class="text-center space-y-8 max-w-4xl mx-auto px-4">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-blue-100/50 dark:bg-blue-500/10 text-blue-700 dark:text-blue-400 text-xs font-black uppercase tracking-[0.2em] rounded-full border border-blue-200 dark:border-blue-500/20 backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-blue-600 animate-pulse"></span>
            Hikayemiz ve Vizyonumuz
        </span>
        <h1 class="text-5xl md:text-7xl font-black text-gray-900 dark:text-white tracking-tighter leading-[1.1]">
            Geleceğin <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 drop-shadow-sm">Çalışma Modelini</span> <br />
            Birlikte İnşa Ediyoruz.
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 font-medium leading-relaxed max-w-3xl mx-auto">
            Vera, bağımsız profesyoneller ile vizyoner şirketleri <strong>%100 güven</strong> ekseninde buluşturan, yeni nesil dijital yetenek ve proje yönetim ekosistemidir. Amacımız sınırları ortadan kaldırmak.
        </p>
    </div>

    <!-- DETAYLI BİLGİ: NASIL BAŞLADIK? -->
    <div class="grid lg:grid-cols-2 gap-16 items-center px-4">
        <div class="space-y-8">
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white tracking-tight">
                Her Şey Bir <span class="text-blue-600 dark:text-blue-400">İhtiyaçtan</span> Doğdu
            </h2>
            <div class="prose prose-lg dark:prose-invert text-gray-600 dark:text-gray-400 font-medium">
                <p>
                    2026 yılının başlarında, kurucularımız kendi freelance kariyerlerinde yaşadıkları ödeme düzensizlikleri ve proje takip zorluklarından yola çıkarak bir karar aldılar: <em>"Neden her iki tarafı da koruyan, adil ve şeffaf bir platform yok?"</em>
                </p>
                <p>
                    İşte Vera bu sorunun cevabı olarak kodlandı. Geliştirdiğimiz <strong class="text-gray-900 dark:text-white">Escrow (Güvenli Havuz)</strong> altyapısı sayesinde artık işverenler "Acaba işim yarım mı kalır?" diye düşünmüyor, freelancerlar ise "Paramı alabilecek miyim?" endişesi yaşamıyor.
                </p>
            </div>
            
            <div class="flex items-center gap-6 pt-4 border-t border-gray-200 dark:border-gray-800">
                <div class="flex flex-col">
                    <span class="text-4xl font-black text-gray-900 dark:text-white">12+</span>
                    <span class="text-sm font-bold text-gray-500 uppercase tracking-wider">Aylık Ar-Ge Süreci</span>
                </div>
                <div class="w-px h-12 bg-gray-200 dark:bg-gray-800"></div>
                <div class="flex flex-col">
                    <span class="text-4xl font-black text-gray-900 dark:text-white">100%</span>
                    <span class="text-sm font-bold text-gray-500 uppercase tracking-wider">Yerli Sermaye</span>
                </div>
            </div>
        </div>
        
        <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-tr from-blue-600/20 to-purple-600/20 rounded-[3rem] blur-2xl transform group-hover:rotate-6 transition-transform duration-700"></div>
            <div class="relative bg-white/80 dark:bg-gray-800/80 backdrop-blur-xl p-8 md:p-12 rounded-[3rem] border border-gray-200 dark:border-gray-700 shadow-xl overflow-hidden">
                <div class="absolute -right-10 -top-10 text-9xl opacity-5 dark:opacity-10 rotate-12">🎯</div>
                <div class="space-y-6 relative z-10">
                    <h3 class="text-2xl font-black text-gray-900 dark:text-white">Neden Vera'yı Seçmelisiniz?</h3>
                    <ul class="space-y-6">
                        <li class="flex items-start gap-4">
                            <div class="w-10 h-10 shrink-0 rounded-xl bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 flex items-center justify-center font-bold text-xl">✓</div>
                            <div>
                                <h4 class="font-bold text-gray-900 dark:text-white text-lg">Gelişmiş B2B Arayüzü</h4>
                                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Sadece tekil kullanıcılar için değil, kurumsal şirketlerin departmanları için de tasarlandı.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-10 h-10 shrink-0 rounded-xl bg-green-100 dark:bg-green-500/20 text-green-600 dark:text-green-400 flex items-center justify-center font-bold text-xl">✓</div>
                            <div>
                                <h4 class="font-bold text-gray-900 dark:text-white text-lg">Finansal Şeffaflık</h4>
                                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Gizli komisyonlar, sürpriz kesintiler yok. Cüzdan hareketlerinizi anlık izleyebilirsiniz.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-10 h-10 shrink-0 rounded-xl bg-purple-100 dark:bg-purple-500/20 text-purple-600 dark:text-purple-400 flex items-center justify-center font-bold text-xl">✓</div>
                            <div>
                                <h4 class="font-bold text-gray-900 dark:text-white text-lg">Adil Puanlama (Meritokrasi)</h4>
                                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Algoritmalarımız manipüle edilemez. Başarı tamamen bitirdiğiniz projelerle ölçülür.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- İSTATİSTİKLER -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 px-4">
        <div class="p-8 bg-white/50 dark:bg-gray-800/50 backdrop-blur-md rounded-[2rem] border border-gray-200 dark:border-gray-700 text-center transform transition-all hover:-translate-y-2 hover:shadow-xl">
            <div class="text-5xl font-black text-blue-600 dark:text-blue-400 mb-2">12K+</div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-widest">Kayıtlı Uzman</div>
        </div>
        <div class="p-8 bg-white/50 dark:bg-gray-800/50 backdrop-blur-md rounded-[2rem] border border-gray-200 dark:border-gray-700 text-center transform transition-all hover:-translate-y-2 hover:shadow-xl">
            <div class="text-5xl font-black text-purple-600 dark:text-purple-400 mb-2">500+</div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-widest">Kurumsal Şirket</div>
        </div>
        <div class="p-8 bg-white/50 dark:bg-gray-800/50 backdrop-blur-md rounded-[2rem] border border-gray-200 dark:border-gray-700 text-center transform transition-all hover:-translate-y-2 hover:shadow-xl">
            <div class="text-5xl font-black text-pink-600 dark:text-pink-400 mb-2">₺8M+</div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-widest">Aylık İşlem Hacmi</div>
        </div>
        <div class="p-8 bg-white/50 dark:bg-gray-800/50 backdrop-blur-md rounded-[2rem] border border-gray-200 dark:border-gray-700 text-center transform transition-all hover:-translate-y-2 hover:shadow-xl">
            <div class="text-5xl font-black text-green-600 dark:text-green-400 mb-2">%99</div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-widest">Müşteri Memnuniyeti</div>
        </div>
    </div>

    <!-- GELECEK HEDEFLERİMİZ -->
    <div class="bg-gray-100/50 dark:bg-gray-800/30 p-10 md:p-16 rounded-[3rem] border border-gray-200 dark:border-gray-800 text-center mx-4 relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiM2YjcyODAiIGZpbGwtb3BhY2l0eT0iMC4xIi8+PC9zdmc+')] opacity-50"></div>
        <div class="relative z-10 max-w-3xl mx-auto space-y-6">
            <h2 class="text-3xl font-black text-gray-900 dark:text-white">Gelecek Vizyonumuz</h2>
            <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed font-medium">
                Önümüzdeki 5 yıl içinde Vera'yı sadece Türkiye'nin değil, Avrupa'nın da en çok tercih edilen bağımsız yetenek yönetim platformu yapmayı hedefliyoruz. Çok yakında eklenecek olan yapay zeka destekli eşleştirme algoritması sayesinde şirketler ve uzmanlar saniyeler içinde mükemmel uyumu yakalayacak.
            </p>
        </div>
    </div>

    <!-- CTA -->
    <div class="bg-gradient-to-r from-gray-900 to-gray-800 dark:from-blue-900 dark:to-purple-900 rounded-[3rem] p-12 md:p-20 text-center relative overflow-hidden shadow-2xl mx-4">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white opacity-5 rounded-full blur-[80px] translate-x-1/2 -translate-y-1/2"></div>
        <h2 class="text-3xl md:text-5xl font-black text-white mb-6 relative z-10 tracking-tight">Kariyeriniz için yeni bir sayfa açın.</h2>
        <p class="text-lg text-gray-300 mb-10 max-w-2xl mx-auto font-medium relative z-10">İster yeteneklerinizi sergilemek isteyen bir uzman, ister doğru ekibi arayan bir şirket olun; Vera yanınızda.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 relative z-10">
            <a href="/Register" class="w-full sm:w-auto px-10 py-4 bg-white text-gray-900 font-black rounded-2xl hover:scale-105 transition-all shadow-xl text-lg">
                Aramıza Katıl
            </a>
            <a href="/Contact" class="w-full sm:w-auto px-10 py-4 bg-transparent border-2 border-white/20 text-white font-bold rounded-2xl hover:bg-white/10 transition-colors text-lg">
                İletişime Geç
            </a>
        </div>
    </div>

</div>
