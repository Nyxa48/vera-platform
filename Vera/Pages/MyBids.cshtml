@page
@model Vera.Pages.MyBidsModel
@{
    ViewData["Title"] = "Projelerim";
    Layout = "_AppLayout";
}

<div class="max-w-7xl mx-auto py-10 px-6 lg:px-8 space-y-10">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <div class="flex items-center gap-3 mb-2">
                @if (Model.UserRole == "Employer")
                {
                    <span class="px-3 py-1 bg-slate-100 dark:bg-white/10 text-slate-700 dark:text-white text-xs font-black rounded-lg uppercase tracking-wider">İş Merkezi</span>
                }
                else
                {
                    <span class="px-3 py-1 bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 text-xs font-black rounded-lg uppercase tracking-wider">Projelerim</span>
                }
            </div>
            <h1 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white tracking-tight">
                @(Model.UserRole == "Employer" ? "İş İlanları ve Proje Yönetimi" : "İş Geçmişi & Aktif Projeler")
            </h1>
            <p class="text-gray-500 font-medium mt-1">
                @(Model.UserRole == "Employer" ? "Yayınladığınız ilanları ve devam eden projeleri buradan yönetebilirsiniz." : "Üstlendiğin ve tamamladığın projelerin burada. 💼")
            </p>
        </div>
    </div>

    @* ÖZET KARTLARI *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-[#1E2330] rounded-[2rem] p-6 border border-gray-100 dark:border-white/5 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-2xl @(Model.UserRole == "Employer" ? "bg-slate-50 dark:bg-white/5 text-slate-500" : "bg-orange-50 dark:bg-orange-500/10 text-orange-500") flex items-center justify-center text-2xl shrink-0">
                @(Model.UserRole == "Employer" ? "📢" : "🔥")
            </div>
            <div>
                <p class="text-gray-400 text-[10px] font-black uppercase tracking-widest">@(Model.UserRole == "Employer" ? "Açık/Aktif İlanlar" : "Aktif Proje")</p>
                <h2 class="text-3xl font-black text-gray-900 dark:text-white">@(Model.UserRole == "Employer" ? ViewData["RawActiveCount"] : Model.ActiveProjects.Count)</h2>
            </div>
        </div>
        <div class="bg-white dark:bg-[#1E2330] rounded-[2rem] p-6 border border-gray-100 dark:border-white/5 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-2xl bg-green-50 dark:bg-green-500/10 text-green-500 flex items-center justify-center text-2xl shrink-0">✅</div>
            <div>
                <p class="text-gray-400 text-[10px] font-black uppercase tracking-widest">Tamamlanan</p>
                <h2 class="text-3xl font-black text-gray-900 dark:text-white">@(Model.UserRole == "Employer" ? ViewData["RawCompletedCount"] : Model.CompletedProjects.Count)</h2>
            </div>
        </div>
        <div class="rounded-[2rem] p-6 text-white shadow-xl flex items-center gap-5 @(Model.UserRole == "Employer" ? "bg-slate-900 dark:bg-[#151A23] border border-slate-800 dark:border-white/10" : "bg-gradient-to-br from-blue-600 to-indigo-700 shadow-blue-500/20")">
            <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center text-2xl shrink-0">💰</div>
            <div>
                <p class="@(Model.UserRole == "Employer" ? "text-slate-400" : "text-blue-100") text-[10px] font-black uppercase tracking-widest">
                    @(Model.UserRole == "Employer" ? "Toplam Harcanan" : "Toplam Kazanç")
                </p>
                <h2 class="text-3xl font-black">₺@Model.TotalEarningsOrSpent.ToString("N0")</h2>
            </div>
        </div>
    </div>

    @* AKTİF PROJELER *@
    @if (Model.ActiveProjects.Any())
    {
        <div class="bg-white dark:bg-[#1E2330] rounded-[2.5rem] border border-gray-100 dark:border-white/5 shadow-sm overflow-hidden">
            <div class="p-8 border-b border-gray-100 dark:border-white/5 flex items-center gap-4 bg-gray-50/50 dark:bg-white/[0.02]">
                <span class="w-10 h-10 rounded-xl bg-orange-100 dark:bg-orange-500/20 text-orange-600 flex items-center justify-center text-lg">🔥</span>
                <h3 class="font-black text-xl text-gray-900 dark:text-white">Aktif Projeler</h3>
            </div>
            <div class="divide-y divide-gray-100 dark:divide-white/5">
                @foreach (var proje in Model.ActiveProjects)
                {
                    <div class="p-8 hover:bg-gray-50 dark:hover:bg-[#151A23]/50 transition-colors">
                        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
                            <div>
                                <h4 class="font-black text-gray-900 dark:text-white text-xl">@proje.Title</h4>
                                <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mt-2 line-clamp-2">@proje.Description</p>
                                <div class="mt-3 flex flex-wrap gap-2">
                                    <span class="px-3 py-1 @(proje.Status == "Açık" ? "bg-green-50 dark:bg-green-500/10 text-green-600 dark:text-green-400 border-green-200 dark:border-green-500/20" : (proje.Status == "İptal Edildi" ? "bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border-red-200 dark:border-red-500/20" : (proje.Status == "Tamamlandı" ? "bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-200 dark:border-blue-500/20" : "bg-orange-50 dark:bg-orange-500/10 text-orange-600 dark:text-orange-400 border-orange-200 dark:border-orange-500/20"))) text-xs font-bold rounded-lg border">@proje.Status</span>
                                    <span class="px-3 py-1 bg-gray-50 dark:bg-white/5 text-gray-600 dark:text-gray-400 text-xs font-bold rounded-lg border border-gray-200 dark:border-white/10">
                                        @(Model.UserRole == "Employer" ? 
                                            (proje.FreelancerId != null ? (Model.UserNames.ContainsKey(proje.FreelancerId.Value) ? Model.UserNames[proje.FreelancerId.Value] : "Bilinmeyen Freelancer") : "Henüz atanmadı") 
                                            : (Model.UserNames.ContainsKey(proje.EmployerId) ? Model.UserNames[proje.EmployerId] : "Bilinmeyen İşveren"))
                                    </span>
                                </div>
                            </div>
                            <div class="sm:text-right shrink-0 space-y-3">
                                <span class="text-2xl font-black @(Model.UserRole == "Employer" ? "text-slate-700 dark:text-slate-300" : "text-blue-600 dark:text-blue-400") block">₺@proje.Budget.ToString("N0")</span>
                                @if (Model.UserRole == "Employer")
                                {
                                    <div class="flex gap-2 justify-end">
                                        @if (proje.Status == "Açık" || proje.Status == "Aktif")
                                        {
                                            <form method="post" asp-page-handler="CancelProject" asp-route-id="@proje.Id" onsubmit="return confirm('Bu ilanı iptal etmek istediğinize emin misiniz? Bu işlem geri alınamaz.');">
                                                <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                                <button type="submit" class="px-4 py-2.5 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white dark:bg-red-500/10 dark:text-red-400 dark:hover:bg-red-500 text-sm font-bold rounded-xl transition-all shadow-sm">
                                                    Kaldır
                                                </button>
                                            </form>
                                        }
                                        <a href="/ProjectDetail?id=@proje.Id" class="px-6 py-2.5 bg-slate-900 hover:bg-slate-800 dark:bg-slate-100 dark:hover:bg-white text-white dark:text-slate-900 text-sm font-bold rounded-xl shadow-lg transition-all hover:-translate-y-0.5 inline-flex items-center gap-2">
                                            Detay
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <a href="/WorkArea?id=@proje.Id" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl shadow-lg transition-all hover:-translate-y-0.5 inline-flex items-center gap-2">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                        Çalışmaya Devam Et
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* TAMAMLANAN PROJELER *@
    <div class="bg-white dark:bg-[#1E2330] rounded-[2.5rem] border border-gray-100 dark:border-white/5 shadow-sm overflow-hidden">
        <div class="p-8 border-b border-gray-100 dark:border-white/5 flex items-center gap-4 bg-gray-50/50 dark:bg-white/[0.02]">
            <span class="w-10 h-10 rounded-xl bg-green-100 dark:bg-green-500/20 text-green-600 flex items-center justify-center text-lg">✅</span>
            <h3 class="font-black text-xl text-gray-900 dark:text-white">Tamamlanan Projeler</h3>
        </div>
        <div class="divide-y divide-gray-100 dark:divide-white/5">
            @if (Model.CompletedProjects.Any())
            {
                @foreach (var proje in Model.CompletedProjects)
                {
                    <div class="p-8 hover:bg-gray-50 dark:hover:bg-[#151A23]/50 transition-colors">
                        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                            <div>
                                <h4 class="font-black text-gray-900 dark:text-white text-xl">@proje.Title</h4>
                                <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mt-2 line-clamp-2">@proje.Description</p>
                                <div class="mt-3 flex flex-wrap gap-2">
                                    <span class="px-3 py-1 bg-green-50 dark:bg-green-500/10 text-green-600 dark:text-green-400 text-xs font-bold rounded-lg border border-green-200 dark:border-green-500/20">Tamamlandı</span>
                                    <span class="px-3 py-1 bg-gray-50 dark:bg-white/5 text-gray-600 dark:text-gray-400 text-xs font-bold rounded-lg border border-gray-200 dark:border-white/10">
                                        @(Model.UserRole == "Employer" ? 
                                            (proje.FreelancerId != null ? (Model.UserNames.ContainsKey(proje.FreelancerId.Value) ? Model.UserNames[proje.FreelancerId.Value] : "Bilinmeyen Freelancer") : "Bilinmeyen") 
                                            : (Model.UserNames.ContainsKey(proje.EmployerId) ? Model.UserNames[proje.EmployerId] : "Bilinmeyen İşveren"))
                                    </span>
                                </div>
                            </div>
                            <div class="sm:text-right shrink-0 space-y-3">
                                <span class="text-2xl font-black @(Model.UserRole == "Employer" ? "text-slate-700 dark:text-slate-300" : "text-green-500") block">₺@proje.Budget.ToString("N0")</span>
                                <a href="/Invoice?id=@proje.Id" target="_blank" class="px-6 py-2.5 bg-gray-100 dark:bg-white/5 hover:bg-gray-200 dark:hover:bg-white/10 text-gray-900 dark:text-white text-sm font-bold rounded-xl transition-all inline-flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                    Faturayı Gör
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="p-12 text-center">
                    <div class="w-20 h-20 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center mx-auto mb-4 text-4xl">📋</div>
                    <h4 class="font-black text-gray-900 dark:text-white text-lg mb-2">Henüz tamamlanan proje yok</h4>
                    <p class="text-sm font-medium text-gray-500">İlk projeni tamamladığında burada görünecek!</p>
                </div>
            }
        </div>
        }
    }
</div>