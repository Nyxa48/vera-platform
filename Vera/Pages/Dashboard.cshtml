@page
@model Vera.Pages.DashboardModel
@{
    ViewData["Title"] = "Kontrol Paneli";
    Layout = "_AppLayout";
}

<div class="max-w-[90rem] mx-auto py-12 px-6 lg:px-12 space-y-10">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-4xl font-black text-gray-900 dark:text-white tracking-tight">
                @if (Model.CurrentUser.Role == "Employer")
                {
                    <span>Yönetim Paneli 🏢</span>
                }
                else
                {
                    <span>Tekrar Hoş Geldin! 👋</span>
                }
            </h1>
            
            <p class="text-lg text-gray-500 dark:text-gray-400 font-medium mt-1">
                @if (Model.CurrentUser.Role == "Employer")
                {
                    <span>Sayın <strong class="text-gray-900 dark:text-white">@Model.CurrentUser.FullName</strong>, kurumunuzun güncel proje ve iş akışını buradan yönetebilirsiniz.</span>
                }
                else
                {
                    <span>Sevgili <strong class="text-gray-900 dark:text-white">@Model.CurrentUser.FullName</strong>, bugün harika işler çıkarmaya hazır mısın? İşte Vera'daki son durumun. ✨</span>
                }
            </p>
        </div>
        
        @if (Model.CurrentUser.Role == "Employer")
        {
            <a href="/PostJob" class="px-8 py-4 bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 font-bold rounded-xl hover:bg-slate-800 dark:hover:bg-white transition-all shadow-lg flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Yeni İlan Yayınla
            </a>
        }
        else
        {
            <a href="/Projects" class="px-8 py-4 bg-white dark:bg-[#1E2330] border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white font-black rounded-2xl hover:border-blue-500 dark:hover:border-blue-400 hover:shadow-lg transition-all shadow-sm flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                Yeni Proje Keşfet
            </a>
        }
    </div>

    @if (Model.CurrentUser.Role == "Employer")
    {
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            @* Kurumsal Kart 1: Aktif İlanlar *@
            <div class="bg-white dark:bg-[#151A23] rounded-2xl p-6 border border-slate-200 dark:border-white/10 shadow-sm flex flex-col relative overflow-hidden group">
                <div class="absolute right-0 top-0 w-24 h-24 bg-slate-50 dark:bg-white/5 rounded-bl-[100px] -z-10 group-hover:scale-110 transition-transform"></div>
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 rounded-lg bg-slate-100 dark:bg-white/10 flex items-center justify-center text-slate-700 dark:text-white">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <p class="text-slate-500 dark:text-gray-400 text-xs font-bold uppercase tracking-widest">Aktif İlanlarım</p>
                    </div>
                </div>
                <div class="flex items-end justify-between mt-auto">
                    <h2 class="text-4xl font-black text-slate-900 dark:text-white">@(Model.MyPostedProjects?.Count ?? 0)</h2>
                    <span class="text-xs font-medium text-slate-500">Yayında</span>
                </div>
            </div>

            @* Kurumsal Kart 2: Gelen Başvurular *@
            <div class="bg-white dark:bg-[#151A23] rounded-2xl p-6 border border-slate-200 dark:border-white/10 shadow-sm flex flex-col relative overflow-hidden group">
                <div class="absolute right-0 top-0 w-24 h-24 bg-blue-50 dark:bg-blue-500/10 rounded-bl-[100px] -z-10 group-hover:scale-110 transition-transform"></div>
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 rounded-lg bg-blue-100 dark:bg-blue-500/20 flex items-center justify-center text-blue-700 dark:text-blue-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-slate-500 dark:text-gray-400 text-xs font-bold uppercase tracking-widest">Gelen Başvurular</p>
                    </div>
                </div>
                <div class="flex items-end justify-between mt-auto">
                    <h2 class="text-4xl font-black text-slate-900 dark:text-white">@Model.TotalApplicants</h2>
                    <span class="text-xs font-medium text-slate-500">Değerlendirilmeyi Bekliyor</span>
                </div>
            </div>

            @* Kurumsal Kart 3: Toplam Harcanan *@
            <div class="bg-slate-900 dark:bg-[#1E2330] rounded-2xl p-6 shadow-xl flex flex-col relative overflow-hidden group border border-slate-800 dark:border-white/5">
                <div class="absolute right-0 top-0 w-32 h-32 bg-white/5 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center text-white">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">Kurumsal Finans</p>
                    </div>
                </div>
                <div class="flex flex-col mt-auto">
                    <span class="text-slate-400 text-[10px] uppercase font-bold tracking-widest mb-1">Toplam Harcanan</span>
                    <h2 class="text-4xl font-black text-white tracking-tighter">₺@Model.TotalSpent.ToString("N0")</h2>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
            <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-[2rem] p-8 text-white shadow-xl shadow-blue-500/20 relative overflow-hidden group flex flex-col justify-between">
                <svg class="absolute -right-6 -top-6 w-40 h-40 text-white opacity-10 group-hover:scale-110 transition-transform duration-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <div>
                    <p class="text-blue-100 text-xs font-black uppercase tracking-widest mb-2 relative z-10">Mevcut Bakiye</p>
                    <h2 class="text-4xl font-black relative z-10 tracking-tighter">₺@Model.CurrentUser.WalletBalance.ToString("N0")</h2>
                </div>
                <div class="mt-6 flex justify-end relative z-10">
                    <div class="w-10 h-10 rounded-xl bg-white/20 backdrop-blur-md flex items-center justify-center text-white shadow-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    </div>
                </div>
            </div>
            
            <div class="bg-white dark:bg-[#1E2330] rounded-[2rem] p-8 border border-gray-100 dark:border-white/5 shadow-sm flex flex-col justify-center">
                <div class="w-14 h-14 rounded-2xl bg-orange-50 dark:bg-orange-500/10 text-orange-600 flex items-center justify-center shrink-0 mb-6">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </div>
                <p class="text-gray-400 text-xs font-black uppercase tracking-widest mb-1">Aktif İşler</p>
                <h2 class="text-4xl font-black text-gray-900 dark:text-white">@Model.TotalActiveJobs</h2>
            </div>

            <div class="bg-white dark:bg-[#1E2330] rounded-[2rem] p-8 border border-gray-100 dark:border-white/5 shadow-sm flex flex-col justify-center">
                <div class="w-14 h-14 rounded-2xl bg-pink-50 dark:bg-pink-500/10 text-pink-600 flex items-center justify-center shrink-0 mb-6">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                </div>
                <p class="text-gray-400 text-xs font-black uppercase tracking-widest mb-1">Yeni Mesajlar</p>
                <h2 class="text-4xl font-black text-gray-900 dark:text-white">@Model.TotalUnreadMsgs</h2>
            </div>

            <div class="bg-white dark:bg-[#1E2330] rounded-[2rem] p-8 border border-gray-100 dark:border-white/5 shadow-sm flex flex-col justify-center">
                <div class="w-14 h-14 rounded-2xl bg-green-50 dark:bg-green-500/10 text-green-500 flex items-center justify-center shrink-0 mb-6">
                    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
                </div>
                <p class="text-gray-400 text-xs font-black uppercase tracking-widest mb-1">Başarı Puanı</p>
                <h2 class="text-4xl font-black text-gray-900 dark:text-white">4.9<span class="text-xl text-gray-400 font-bold">/5</span></h2>
            </div>
        </div>

        @* FREELANCER AKTİF İŞ KARTI *@
        @if (Model.MyActiveProject != null)
        {
            <div class="bg-gradient-to-r from-indigo-50 to-blue-50 dark:from-indigo-500/5 dark:to-blue-500/5 rounded-[2.5rem] p-8 border border-indigo-100 dark:border-indigo-500/10 shadow-sm">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                    <div class="flex items-start gap-5">
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-indigo-500 to-blue-600 flex items-center justify-center text-white text-2xl shadow-lg shadow-indigo-500/30 shrink-0">
                            🔥
                        </div>
                        <div>
                            <p class="text-xs font-black text-indigo-500 dark:text-indigo-400 uppercase tracking-widest mb-1">Üzerinde Çalıştığın Proje</p>
                            <h3 class="text-2xl font-black text-gray-900 dark:text-white">@Model.MyActiveProject.Title</h3>
                            <p class="text-sm font-medium text-gray-500 mt-1">Bütçe: ₺@Model.MyActiveProject.Budget.ToString("N0") · @(Model.MyActiveProject.IsHourly ? "Saatlik" : "Sabit Fiyat")</p>
                        </div>
                    </div>
                    <a href="/WorkArea?id=@Model.MyActiveProject.Id" class="px-8 py-4 bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-700 hover:to-blue-700 text-white font-black rounded-2xl transition-all shadow-lg shadow-indigo-500/30 hover:-translate-y-0.5 flex items-center gap-2 shrink-0">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        Çalışma Alanına Git
                    </a>
                </div>
                <div class="mt-6">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-black text-gray-500 uppercase tracking-widest">İlerleme</span>
                        <span class="text-sm font-black @(Model.MyActiveProjectProgress == 100 ? "text-green-500" : "text-indigo-600 dark:text-indigo-400")">%@Model.MyActiveProjectProgress</span>
                    </div>
                    <div class="w-full bg-white/50 dark:bg-white/5 rounded-full h-2.5 overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-700 @(Model.MyActiveProjectProgress == 100 ? "bg-gradient-to-r from-green-400 to-emerald-500" : "bg-gradient-to-r from-indigo-500 to-blue-500")" style="width: @(Model.MyActiveProjectProgress)%"></div>
                    </div>
                </div>
            </div>
        }
    }

    <div class="grid xl:grid-cols-3 gap-8 items-stretch">
        
        <div class="xl:col-span-2 bg-white dark:bg-[#151A23] rounded-2xl border border-slate-200 dark:border-white/10 shadow-sm overflow-hidden flex flex-col h-full">
            @if (Model.CurrentUser.Role == "Employer")
            {
                <div class="p-6 border-b border-slate-200 dark:border-white/10 flex justify-between items-center bg-slate-50 dark:bg-white/[0.02]">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-slate-200 dark:bg-white/10 text-slate-700 dark:text-white flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
                        </div>
                        <h3 class="font-bold text-lg text-slate-900 dark:text-white">Açık İlanlar ve Durumları</h3>
                    </div>
                </div>
                <div class="divide-y divide-slate-100 dark:divide-white/5 flex-1">
                    @if (Model.MyPostedProjects != null && Model.MyPostedProjects.Any())
                    {
                        foreach (var job in Model.MyPostedProjects)
                        {
                            <div class="p-6 hover:bg-slate-50 dark:hover:bg-white/[0.02] transition-colors group">
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-3 mb-1">
                                            <h4 class="font-bold text-slate-900 dark:text-white text-lg">@job.Title</h4>
                                            @if(job.Status == "Açık") {
                                                <span class="px-2.5 py-0.5 bg-green-100 text-green-700 dark:bg-green-500/20 dark:text-green-400 text-[10px] font-bold rounded uppercase tracking-wider">Açık</span>
                                            } else if(job.Status == "Aktif") {
                                                <span class="px-2.5 py-0.5 bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-400 text-[10px] font-bold rounded uppercase tracking-wider">Devam Ediyor</span>
                                            } else {
                                                <span class="px-2.5 py-0.5 bg-slate-200 text-slate-700 dark:bg-white/10 dark:text-slate-300 text-[10px] font-bold rounded uppercase tracking-wider">@job.Status</span>
                                            }
                                        </div>
                                        <p class="text-sm text-slate-500 dark:text-gray-400 line-clamp-1">@job.Description</p>
                                        
                                        @if (job.Status == "Aktif" && Model.ProjectProgress.ContainsKey(job.Id))
                                        {
                                            <div class="mt-4 pt-3 border-t border-slate-100 dark:border-white/5">
                                                <div class="flex items-center justify-between mb-1">
                                                    <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">İlerleme Durumu</span>
                                                    <span class="text-[10px] font-black text-blue-600 dark:text-blue-400">%@Model.ProjectProgress[job.Id]</span>
                                                </div>
                                                <div class="w-full bg-slate-100 dark:bg-white/5 rounded-full h-1.5 overflow-hidden">
                                                    <div class="h-full rounded-full transition-all duration-700 bg-gradient-to-r from-blue-500 to-indigo-500" style="width: @(Model.ProjectProgress[job.Id])%"></div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="sm:text-right shrink-0 flex flex-col sm:items-end gap-2">
                                        <span class="text-sm font-bold text-slate-700 dark:text-slate-300">Bütçe: ₺@job.Budget.ToString("N0")</span>
                                        <a href="/ProjectDetail?id=@job.Id" class="text-xs font-bold text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors flex items-center gap-1">
                                            İlanı Yönet <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-8 text-center text-slate-500">Henüz yayınlanmış bir iş ilanınız bulunmuyor.</div>
                    }
                </div>
            }
            else
            {
                <div class="p-8 border-b border-gray-100 dark:border-white/5 flex justify-between items-center bg-gray-50/50 dark:bg-white/[0.02]">
                    <div class="flex items-center gap-4">
                        <span class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-500/20 text-blue-600 flex items-center justify-center text-lg">💼</span>
                        <h3 class="font-black text-xl text-gray-900 dark:text-white">Gelen İş Teklifleri</h3>
                    </div>
                    <span class="px-3 py-1.5 bg-red-500 text-white text-xs font-bold rounded-lg shadow-md animate-pulse">Yeni Teklifler</span>
                </div>
                <div class="divide-y divide-gray-100 dark:divide-white/5 flex-1">
                    @if (Model.ActiveProjects != null && Model.ActiveProjects.Any())
                    {
                        foreach (var proje in Model.ActiveProjects)
                        {
                            <div class="p-8 hover:bg-gray-50 dark:hover:bg-[#151A23]/50 transition-colors group">
                                <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
                                    <div>
                                        <h4 class="font-black text-gray-900 dark:text-white text-xl">@proje.Title</h4>
                                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mt-2">@proje.Description</p>
                                    </div>
                                    <div class="sm:text-right shrink-0">
                                        <span class="text-2xl font-black text-blue-600 dark:text-blue-400">₺@proje.Budget.ToString("N0")</span>
                                    </div>
                                </div>
                                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mt-6 pt-6 border-t border-gray-100 dark:border-white/5">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-sm font-bold text-gray-600 dark:text-gray-300">🏢</div>
                                        <span class="text-sm font-bold text-gray-700 dark:text-gray-300">Şirket ID: @proje.EmployerId</span>
                                    </div>
                                    <div class="flex gap-3 w-full sm:w-auto">
                                        @if (Model.TotalActiveJobs > 0)
                                        {
                                            <button disabled class="flex-1 sm:flex-none px-6 py-2.5 bg-gray-300 text-white text-sm font-bold rounded-xl cursor-not-allowed opacity-60">
                                                Mevcut İşini Bitir
                                            </button>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="AcceptJob" asp-route-projectId="@proje.Id">
                                                <button type="submit" class="px-6 py-2.5 bg-green-500 hover:bg-green-600 text-white text-sm font-bold rounded-xl shadow-lg transition-all hover:-translate-y-0.5">
                                                    Kabul Et
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-8 text-center text-gray-500">Şu anda aktif bir teklif bulunmuyor.</div>
                    }
                </div>
            }
        </div>

        <div class="xl:col-span-1 bg-white dark:bg-[#1E2330] rounded-[2.5rem] border border-gray-100 dark:border-white/5 shadow-sm overflow-hidden flex flex-col h-full">
            <div class="p-8 border-b border-gray-100 dark:border-white/5 flex justify-between items-center bg-gray-50/50 dark:bg-white/[0.02]">
                <div class="flex items-center gap-4">
                    <span class="w-10 h-10 rounded-xl bg-pink-100 dark:bg-pink-500/20 text-pink-600 flex items-center justify-center text-lg">💬</span>
                    <h3 class="font-black text-xl text-gray-900 dark:text-white">Mesajlar</h3>
                </div>
                <a href="/Messages" class="text-sm font-bold text-blue-600 hover:text-blue-500 transition-colors">Tümünü Gör</a>
            </div>
            
            <div class="p-4 space-y-2 flex-1 overflow-y-auto">
                @if (Model.RecentMessages != null && Model.RecentMessages.Any())
                {
                    foreach (var mesaj in Model.RecentMessages)
                    {
                        <div class="flex gap-4 p-4 rounded-2xl hover:bg-gray-50 dark:hover:bg-[#151A23] transition-colors cursor-pointer border border-transparent dark:hover:border-white/5 @(mesaj.IsRead ? "opacity-80" : "")">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-black shrink-0 shadow-sm">
                                @(Model.SenderNames.ContainsKey(mesaj.SenderId) ? Model.SenderNames[mesaj.SenderId].Substring(0, 1) : "U")
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex justify-between items-baseline mb-1">
                                    <h4 class="font-bold text-gray-900 dark:text-white truncate">
                                        @(Model.SenderNames.ContainsKey(mesaj.SenderId) ? Model.SenderNames[mesaj.SenderId] : "Bilinmeyen")
                                    </h4>
                                    @if (!mesaj.IsRead)
                                    {
                                        <span class="text-[10px] font-black text-blue-600 bg-blue-50 dark:bg-blue-500/10 px-2 py-1 rounded-md uppercase tracking-wider">Yeni</span>
                                    }
                                    else
                                    {
                                        <span class="text-[10px] font-bold text-gray-400">@mesaj.SentAt.ToString("HH:mm")</span>
                                    }
                                </div>
                                <p class="text-xs font-medium text-gray-500 truncate mt-1">@mesaj.Content</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-xs text-gray-500">Henüz yeni mesajınız yok.</div>
                }
            </div>
        </div>
    </div>
</div>