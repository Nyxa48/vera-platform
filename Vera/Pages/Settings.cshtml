@page
@model Vera.Pages.SettingsModel
@{
    ViewData["Title"] = "Hesap Ayarları";
    Layout = "_AppLayout";
}
<div class="max-w-6xl mx-auto py-10 px-6 lg:px-8">
    <div class="mb-10">
        <h1 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white tracking-tight">Hesap Ayarları</h1>
        <p class="text-gray-500 dark:text-gray-400 mt-2 font-medium">Profilinizi, güvenlik tercihlerinizi ve bildirimlerinizi yönetin.</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-10">
        <aside class="lg:w-1/4 shrink-0">
            <nav class="flex flex-col gap-2 bg-white dark:bg-[#1E2330] p-4 rounded-3xl border border-gray-100 dark:border-white/5 shadow-sm">
                <button onclick="switchTab('profile')" id="btn-profile" class="tab-btn flex items-center gap-3 w-full text-left px-4 py-3 rounded-2xl bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
                    Profil Bilgileri
                </button>
                <button onclick="switchTab('security')" id="btn-security" class="tab-btn flex items-center gap-3 w-full text-left px-4 py-3 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-white/5 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
                    Şifre & Güvenlik
                </button>
                <button onclick="switchTab('payment')" id="btn-payment" class="tab-btn flex items-center gap-3 w-full text-left px-4 py-3 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-white/5 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" /></svg>
                    Ödeme Yöntemleri
                </button>
                <button onclick="switchTab('notifications')" id="btn-notifications" class="tab-btn flex items-center gap-3 w-full text-left px-4 py-3 rounded-2xl text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-white/5 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
                    Bildirimler
                </button>
                <div class="my-2 border-t border-gray-100 dark:border-white/5"></div>
                <button onclick="openDeleteModal()" class="flex items-center gap-3 w-full text-left px-4 py-3 rounded-2xl text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 font-bold transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                    Hesabı Sil
                </button>
            </nav>
        </aside>

        <main class="lg:flex-1 bg-white dark:bg-[#1E2330] rounded-[2.5rem] p-8 md:p-10 border border-gray-100 dark:border-white/5 shadow-sm">
            
            <div id="tab-profile" class="tab-content block">
                <form method="post" class="space-y-8">
                    
                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="p-4 bg-green-500/10 border border-green-500/20 text-green-500 rounded-xl font-bold text-sm text-center">
                            @Model.SuccessMessage
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="p-4 bg-red-500/10 border border-red-500/20 text-red-500 rounded-xl font-bold text-sm text-center">
                            @Model.ErrorMessage
                        </div>
                    }

                    <div class="flex items-center gap-6 pb-8 border-b border-gray-100 dark:border-white/5">
                        <div class="w-24 h-24 rounded-full bg-blue-600 flex items-center justify-center text-white text-3xl font-black">
                            @(string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <h3 class="text-lg font-black dark:text-white">Profil Fotoğrafı</h3>
                            <p class="text-sm text-gray-500 mt-1 mb-3">PNG veya JPG. Maksimum 5MB.</p>
                            <div class="flex gap-2">
                                <button type="button" class="px-4 py-2 bg-blue-500/10 text-blue-600 dark:text-blue-400 text-sm font-bold rounded-lg hover:bg-blue-500/20 transition-colors">Yükle</button>
                                <button type="button" class="px-4 py-2 text-gray-500 hover:text-red-500 text-sm font-bold transition-colors">Kaldır</button>
                            </div>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">Ad Soyad</label>
                            <input asp-for="FullName" type="text" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                        </div>
                        <div>
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">E-Posta</label>
                            <input type="hidden" asp-for="Email" />
                            <input type="email" value="@Model.Email" disabled class="w-full mt-2 bg-gray-100 dark:bg-[#151A23]/50 border border-gray-200 dark:border-white/5 rounded-xl px-4 py-3 text-gray-500 cursor-not-allowed" />
                        </div>
                        <div class="col-span-2">
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">Ünvan / Uzmanlık Alanı</label>
                            <input asp-for="Title" type="text" placeholder="Örn: Senior .NET Developer" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                        </div>
                        <div class="col-span-2">
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">Hakkımda</label>
                            <textarea asp-for="About" rows="4" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all resize-none"></textarea>
                        </div>
                        <div class="col-span-2">
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">Yetenekler & Uzmanlıklar</label>
                            <input asp-for="Skills" type="text" placeholder="Virgülle ayırarak yazın: C#, .NET Core, SQL Server, Docker" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                            <p class="text-[10px] text-gray-400 mt-2 pl-1 font-medium">💡 Her yeteneği virgülle ayırarak yazın. Profilinizde ve Uzmanlar sayfasında gösterilecek.</p>
                        </div>
                    </div>
                    <div class="flex justify-end pt-4">
                        <button type="submit" class="px-8 py-3 bg-blue-600 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 hover:-translate-y-0.5 transition-all">
                            Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>

            <div id="tab-security" class="tab-content hidden">
                <form method="post" class="space-y-8">
                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="p-4 bg-green-500/10 border border-green-500/20 text-green-500 rounded-xl font-bold text-sm text-center mb-6">
                            @Model.SuccessMessage
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="p-4 bg-red-500/10 border border-red-500/20 text-red-500 rounded-xl font-bold text-sm text-center mb-6">
                            @Model.ErrorMessage
                        </div>
                    }
                    <h3 class="text-xl font-black text-gray-900 dark:text-white mb-6">Şifre Değiştir</h3>
                    <div class="space-y-4">
                        <input type="hidden" asp-for="FullName" />
                        <input type="hidden" asp-for="Email" />
                        
                        <div>
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">Mevcut Şifre</label>
                            <input asp-for="CurrentPassword" type="password" placeholder="••••••••" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                        </div>
                        <div>
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">Yeni Şifre</label>
                            <input asp-for="NewPassword" type="password" placeholder="••••••••" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                        </div>
                        <div>
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">Yeni Şifre (Tekrar)</label>
                            <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                        </div>
                    </div>
                    <div class="flex justify-end pt-4"><button type="submit" class="px-8 py-3 bg-blue-600 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 hover:-translate-y-0.5 transition-all">Şifreyi Güncelle</button></div>
                </form>
            </div>

            <div id="tab-payment" class="tab-content hidden">
                <form method="post" class="space-y-8">
                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="p-4 bg-green-500/10 border border-green-500/20 text-green-500 rounded-xl font-bold text-sm text-center mb-6">
                            @Model.SuccessMessage
                        </div>
                    }

                    <input type="hidden" asp-for="FullName" />
                    <input type="hidden" asp-for="Email" />

                    <h3 class="text-xl font-black text-gray-900 dark:text-white mb-6">Banka ve Ödeme Bilgileri</h3>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="text-[11px] font-black text-gray-400 uppercase tracking-widest pl-1">IBAN Numarası</label>
                            <input asp-for="IBAN" type="text" placeholder="TR00 0000 0000 0000 0000 0000 00" class="w-full mt-2 bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white font-mono tracking-widest focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                            <p class="text-[10px] text-gray-400 mt-2 pl-1 font-medium">💡 Cüzdanınızdaki bakiyeyi çekmek için IBAN bilginizin doğru olması zorunludur.</p>
                        </div>
                    </div>

                    <div class="flex justify-end pt-4">
                        <button type="submit" class="px-8 py-3 bg-blue-600 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 hover:-translate-y-0.5 transition-all">IBAN'ı Kaydet</button>
                    </div>
                </form>
            </div>

            <div id="tab-notifications" class="tab-content hidden space-y-8">
                <h3 class="text-xl font-black text-gray-900 dark:text-white mb-6">E-Posta Bildirimleri</h3>
                <div class="space-y-4">
                    <label class="flex items-center justify-between p-4 bg-gray-50 dark:bg-[#151A23] rounded-xl border border-gray-200 dark:border-white/10 cursor-pointer">
                        <div>
                            <p class="text-gray-900 dark:text-white font-bold">Yeni Mesajlar</p>
                            <p class="text-gray-500 dark:text-gray-400 text-xs mt-1 font-medium">Biri size mesaj attığında e-posta gönderilir.</p>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 accent-blue-600 cursor-pointer" />
                    </label>
                    <label class="flex items-center justify-between p-4 bg-gray-50 dark:bg-[#151A23] rounded-xl border border-gray-200 dark:border-white/10 cursor-pointer">
                        <div>
                            <p class="text-gray-900 dark:text-white font-bold">Teklif Durumları</p>
                            <p class="text-gray-500 dark:text-gray-400 text-xs mt-1 font-medium">Teklifiniz onaylandığında veya reddedildiğinde bildirir.</p>
                        </div>
                        <input type="checkbox" checked class="w-5 h-5 accent-blue-600 cursor-pointer" />
                    </label>
                </div>
            </div>
        </main>
    </div>
</div>

<div id="deleteModal" class="fixed inset-0 z-[100] hidden items-center justify-center">
    <div class="absolute inset-0 bg-gray-900/40 dark:bg-black/60 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
    <div class="relative bg-white dark:bg-[#1E2330] w-full max-w-md p-8 rounded-[2rem] border border-gray-100 dark:border-white/10 shadow-2xl scale-95 transform transition-transform" id="modalBox">
        <div class="w-16 h-16 rounded-full bg-red-50 dark:bg-red-500/10 text-red-600 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
        </div>
        <h3 class="text-2xl font-black text-center text-gray-900 dark:text-white mb-2">Emin misiniz?</h3>
        <p class="text-center text-gray-500 dark:text-gray-400 text-sm mb-6 font-medium">Hesabınızı silmek kalıcı bir işlemdir. Devam etmek için lütfen şifrenizi girin.</p>
        <div class="space-y-2 mb-8">
            <label class="text-[11px] font-black text-gray-500 dark:text-gray-400 uppercase tracking-widest pl-2">Hesap Şifreniz</label>
            <input type="password" placeholder="Şifrenizi girin..." class="w-full bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-red-500 transition-all" />
        </div>
        <div class="flex gap-4">
            <button onclick="closeDeleteModal()" class="flex-1 py-3 bg-gray-100 dark:bg-white/5 hover:bg-gray-200 dark:hover:bg-white/10 text-gray-700 dark:text-gray-300 font-bold rounded-xl transition-colors">Vazgeç</button>
            <button class="flex-1 py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl shadow-lg shadow-red-500/30 transition-all">Kalıcı Olarak Sil</button>
        </div>
    </div>
</div>

<script>
    function switchTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('bg-blue-50', 'dark:bg-blue-500/10', 'text-blue-600', 'dark:text-blue-400');
            btn.classList.add('text-gray-600', 'dark:text-gray-400');
        });
        document.getElementById('tab-' + tabId).classList.remove('hidden');
        const activeBtn = document.getElementById('btn-' + tabId);
        activeBtn.classList.remove('text-gray-600', 'dark:text-gray-400');
        activeBtn.classList.add('bg-blue-50', 'dark:bg-blue-500/10', 'text-blue-600', 'dark:text-blue-400');
    }
    function openDeleteModal() {
        const modal = document.getElementById('deleteModal');
        const box = document.getElementById('modalBox');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => box.classList.remove('scale-95'), 10);
    }
    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        const box = document.getElementById('modalBox');
        box.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 150);
    }
</script>