@page
@model ErrorModel
@{
    ViewData["Title"] = "Sayfa Bulunamadı";
    Layout = "_Layout";
}

<div class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="text-center space-y-8 relative">
        
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-pink-500/20 dark:bg-pink-500/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
            <h1 class="text-8xl md:text-9xl font-black text-gray-900 dark:text-white tracking-tighter drop-shadow-sm">
                4<span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-600 to-purple-600">0</span>4
            </h1>
            
            <div class="text-6xl my-6 animate-bounce">🛸</div>
            
            <h2 class="text-2xl md:text-3xl font-bold text-gray-800 dark:text-gray-200 mb-4">
                Uzayın derinliklerinde kaybolduk!
            </h2>
            
            <p class="text-gray-500 dark:text-gray-400 font-medium max-w-md mx-auto mb-8">
                Aradığınız sayfa silinmiş, adı değiştirilmiş veya geçici olarak kullanım dışı kalmış olabilir.
            </p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <p class="text-xs text-gray-400 mb-8 bg-gray-100 dark:bg-white/5 inline-block px-3 py-1 rounded-lg">
                    Hata Detayı: <code class="font-mono text-pink-500">@Model.ErrorMessage</code>
                </p>
            }

            <div>
                <a href="/Index" class="inline-flex items-center gap-2 px-8 py-4 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold rounded-2xl shadow-lg hover:-translate-y-1 transition-transform">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Ana Sayfaya Dön
                </a>
            </div>
        </div>

    </div>
</div>