@page
@model Vera.Pages.LoginModel
@{
    ViewData["Title"] = "Tekrar Hoşgeldin";
}
<div class="min-h-[85vh] flex items-center justify-center p-6">
    <div class="max-w-5xl w-full bg-white dark:bg-[#1E2330] rounded-[3rem] shadow-2xl overflow-hidden flex flex-col md:flex-row border border-gray-100 dark:border-gray-800">
        
        <div class="md:w-1/2 p-12 space-y-8">
            <div class="space-y-2">
                <h2 class="text-3xl font-black tracking-tighter">Tekrar hoş geldiniz</h2>
                <p class="text-gray-400 text-sm font-medium">Devam etmek için giriş yapın.</p>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <button class="w-full py-3.5 border border-gray-200 dark:border-gray-700 dark:bg-[#151923] rounded-2xl flex items-center justify-center gap-2 hover:bg-gray-50 dark:hover:bg-gray-800 transition font-bold text-xs">
                    <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="w-4 h-4" />
                    Google
                </button>
                <button class="w-full py-3.5 bg-[#1877F2] text-white rounded-2xl flex items-center justify-center gap-2 hover:bg-[#166fe5] transition font-bold text-xs">
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
                    Facebook
                </button>
            </div>

            <div class="relative flex py-2 items-center">
                <div class="flex-grow border-t border-gray-100 dark:border-gray-700"></div>
                <span class="flex-shrink mx-4 text-gray-400 text-[10px] uppercase tracking-widest font-black">YA DA</span>
                <div class="flex-grow border-t border-gray-100 dark:border-gray-700"></div>
            </div>

            <form method="post" class="space-y-4">
                <input name="Email" placeholder="E-posta veya kullanıcı adı" class="w-full px-5 py-3.5 rounded-2xl bg-gray-50 dark:bg-[#151923] border-none focus:ring-2 ring-blue-500 transition-all text-sm outline-none">
                <input name="Password" type="password" placeholder="Şifre" class="w-full px-5 py-3.5 rounded-2xl bg-gray-50 dark:bg-[#151923] border-none focus:ring-2 ring-blue-500 transition-all text-sm outline-none">
                
                <div class="flex justify-between items-center text-xs px-1">
                    <label class="flex items-center gap-2 cursor-pointer text-gray-500 font-medium">
                        <input type="checkbox" name="RememberMe" value="true" class="rounded text-blue-600 focus:ring-0 dark:bg-[#151923] dark:border-gray-700"> Beni hatırla
                    </label>
                    <a href="#" class="text-blue-600 font-bold hover:underline">Şifremi Unuttum</a>
                </div>

                <button class="w-full bg-blue-600 text-white font-bold py-4 rounded-2xl shadow-lg shadow-blue-500/30 hover:bg-blue-700 transition active:scale-95 text-sm">Giriş Yap</button>
            </form>

            <p class="text-center text-xs text-gray-500">Hesabınız yok mu? <a asp-page="/Register" class="text-blue-600 font-bold hover:underline">Kaydolun</a></p>
        </div>

        <div class="md:w-1/2 bg-gradient-to-br from-blue-500 to-indigo-700 p-12 flex flex-col justify-between text-white relative">
            <div class="space-y-6">
                <h3 class="text-5xl font-black leading-tight tracking-tighter italic">işini <br /> büyüt.</h3>
                <p class="text-blue-100 text-base font-medium opacity-90 leading-relaxed">Binlerce freelancer projelerini Vera ile profesyonelce yönetiyor.</p>
            </div>
            
            <div class="relative z-10 pt-8 border-t border-white/20">
                <div class="flex items-center gap-5">
                    <div class="flex -space-x-3 hover:space-x-1 transition-all duration-300">
                        <img class="w-11 h-11 rounded-full border-2 border-indigo-400 object-cover shadow-lg" src="https://i.pravatar.cc/100?img=11" alt="User 1">
                        <img class="w-11 h-11 rounded-full border-2 border-indigo-400 object-cover shadow-lg" src="https://i.pravatar.cc/100?img=33" alt="User 2">
                        <img class="w-11 h-11 rounded-full border-2 border-indigo-400 object-cover shadow-lg" src="https://i.pravatar.cc/100?img=12" alt="User 3">
                        <div class="w-11 h-11 rounded-full border-2 border-indigo-400 bg-white/20 backdrop-blur-md flex items-center justify-center text-[10px] font-black text-white shadow-lg">
                            +12k
                        </div>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[11px] font-black text-blue-100 uppercase tracking-widest">BÜYÜYEN AİLE</p>
                        <p class="text-[11px] text-blue-200 font-medium">12.000+ profesyonel Vera kullanıyor.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div id="errorPopup" class="fixed inset-0 z-[100] flex items-center justify-center bg-gray-900/40 dark:bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <div class="bg-white dark:bg-[#1E2330] rounded-[2.5rem] p-8 max-w-sm w-full mx-4 shadow-2xl transform scale-95 transition-transform duration-300 border border-gray-100 dark:border-white/5 text-center relative">
            
            <button onclick="closeErrorPopup()" class="absolute top-5 right-5 text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            
            <div class="w-20 h-20 bg-pink-50 dark:bg-pink-500/10 rounded-[1.5rem] flex items-center justify-center mx-auto mb-6 rotate-3">
                <span class="text-4xl">🧐</span>
            </div>
            
            <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2 tracking-tight">Giriş Başarısız!</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-8 font-medium">@Model.ErrorMessage <br> Lütfen bilgilerini kontrol et.</p>
            
            <button onclick="closeErrorPopup()" class="w-full py-4 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold rounded-2xl shadow-lg hover:-translate-y-0.5 transition-all active:scale-95">
                Tekrar Dene
            </button>
        </div>
    </div>

    <script>
        // Sayfa yüklendiği an Pop-up'ı havalı bir şekilde ekrana getiren animasyon
        document.addEventListener('DOMContentLoaded', function() {
            const popup = document.getElementById('errorPopup');
            const popupInner = popup.querySelector('div');
            
            // 50ms bekleyip CSS transition'ları tetikliyoruz
            setTimeout(() => {
                popup.classList.remove('opacity-0');
                popup.classList.add('opacity-100');
                popupInner.classList.remove('scale-95');
                popupInner.classList.add('scale-100');
            }, 50);
        });

        // Kapatma Animasyonu
        function closeErrorPopup() {
            const popup = document.getElementById('errorPopup');
            const popupInner = popup.querySelector('div');
            
            popup.classList.remove('opacity-100');
            popup.classList.add('opacity-0');
            popupInner.classList.remove('scale-100');
            popupInner.classList.add('scale-95');
            
            // Animasyon bitince HTML'den tamamen gizle
            setTimeout(() => {
                popup.style.display = 'none';
            }, 300);
        }
    </script>
}