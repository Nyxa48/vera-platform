@page
@model Vera.Pages.ContactModel
@{
    ViewData["Title"] = "İletişim & Destek";
}
<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <!-- Arka Plan Süsleme (Glow) -->
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/4 w-[800px] h-[600px] bg-gradient-to-bl from-blue-600/20 via-purple-600/10 to-transparent rounded-full blur-[120px] pointer-events-none z-0 dark:opacity-100 opacity-50"></div>

    <div class="relative z-10 grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        
        <!-- Sol Kısım: Yazılar ve İletişim Kartları -->
        <div class="space-y-10">
            <div class="space-y-6">
                <h1 class="text-5xl lg:text-7xl font-black text-gray-900 dark:text-white tracking-tighter">
                    Bize <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-500">Ulaşın.</span>
                </h1>
                <p class="text-lg text-gray-600 dark:text-gray-400 font-medium max-w-lg">
                    Platformumuzda karşılaştığınız şikayetler, öneriler veya her türlü destek talebi için doğrudan yönetim ekibimize mesaj gönderebilirsiniz. 
                </p>
                <div class="inline-flex items-center gap-3 px-4 py-2 bg-green-50 dark:bg-green-500/10 text-green-700 dark:text-green-400 rounded-xl font-bold text-sm border border-green-200 dark:border-green-500/20">
                    <span class="relative flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                    </span>
                    Destek ekibimiz şu an aktif.
                </div>
            </div>

            <div class="space-y-4">
                <!-- E-Posta Kartı -->
                <div class="flex items-start gap-5 p-6 bg-white dark:bg-[#1E2330] rounded-3xl border border-gray-100 dark:border-white/[0.05] shadow-lg shadow-gray-200/50 dark:shadow-none hover:border-blue-500/50 transition-colors group cursor-pointer">
                    <div class="w-14 h-14 rounded-2xl bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">E-posta (Direkt İletişim)</h3>
                        <a href="mailto:admin@vera.com" class="text-sm font-medium text-gray-500 dark:text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">admin@vera.com</a>
                    </div>
                </div>

                <!-- Ofis Kartı -->
                <div class="flex items-start gap-5 p-6 bg-white dark:bg-[#1E2330] rounded-3xl border border-gray-100 dark:border-white/[0.05] shadow-lg shadow-gray-200/50 dark:shadow-none hover:border-pink-500/50 transition-colors group cursor-pointer">
                    <div class="w-14 h-14 rounded-2xl bg-pink-50 dark:bg-pink-500/10 text-pink-600 dark:text-pink-400 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">Merkez Ofis</h3>
                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400 leading-relaxed">Yazılım Vadisi, Kat: 4<br />İstanbul, Türkiye</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ Kısım: Form -->
        <div class="bg-white dark:bg-[#1E2330] p-8 md:p-10 rounded-[2.5rem] shadow-2xl dark:shadow-blue-900/10 border border-gray-100 dark:border-white/[0.05] relative">
            
            <div class="mb-6">
                <h2 class="text-2xl font-black text-gray-900 dark:text-white">Destek Talebi Oluştur</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium mt-1">Mesajınız doğrudan admin paneline düşer ve size platform içi 'Mesajlar' bölümünden yanıt verilir.</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="mb-6 p-4 bg-green-50 dark:bg-green-500/10 border border-green-200 dark:border-green-500/30 rounded-2xl flex items-center gap-3 text-green-700 dark:text-green-400 font-medium">
                    <span class="text-xl">✅</span>
                    @Model.SuccessMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-6 p-4 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 rounded-2xl flex items-center gap-3 text-red-700 dark:text-red-400 font-medium">
                    <span class="text-xl">❌</span>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post" class="space-y-6">
                
                <div class="space-y-2">
                    <label class="text-[11px] font-black text-gray-500 dark:text-gray-400 uppercase tracking-widest pl-1">Konu Başlığı</label>
                    <input type="text" asp-for="Subject" placeholder="Örn: Bakiye yükleme sorunu, Şikayet vb." class="w-full bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-2xl px-5 py-4 text-sm font-medium text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all placeholder-gray-400 dark:placeholder-gray-600" required />
                </div>

                <div class="space-y-2">
                    <label class="text-[11px] font-black text-gray-500 dark:text-gray-400 uppercase tracking-widest pl-1">Mesajınız / Şikayetiniz</label>
                    <textarea asp-for="MessageBody" rows="5" placeholder="Lütfen detaylı bilgi veriniz..." class="w-full bg-gray-50 dark:bg-[#151A23] border border-gray-200 dark:border-white/10 rounded-2xl px-5 py-4 text-sm font-medium text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all placeholder-gray-400 dark:placeholder-gray-600 resize-none" required></textarea>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold py-4 rounded-2xl shadow-lg shadow-blue-500/30 transition-all hover:-translate-y-1 active:scale-95 text-lg mt-4 flex items-center justify-center gap-2">
                    <span>Yönetime Gönder</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                </button>
            </form>
        </div>
        
    </div>
</div>